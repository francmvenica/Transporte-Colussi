---
import ContactForm from './ContactForm';
import { SITE } from '../config/site';
---

<section id="contactos" class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-brand-red font-semibold text-sm uppercase tracking-widest mb-3">Contacto</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-neutral-900">
        Hablemos de tu carga
      </h2>
      <p class="mt-4 text-lg text-neutral-600 max-w-2xl mx-auto">
        Completá el formulario o contactanos directamente. Respondemos en menos de 24 horas hábiles.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
      <!-- Form (3 cols) -->
      <div class="lg:col-span-3 bg-neutral-50 rounded-2xl p-8 border border-neutral-200">
        <ContactForm client:visible />
      </div>

      <!-- Info + Map (2 cols) -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Map -->
        <div class="rounded-2xl overflow-hidden shadow-lg h-64">
          <iframe
            src={SITE.maps.embedUrl}
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación de Transporte Colussi en Google Maps"
          ></iframe>
        </div>

        <!-- Contact details -->
        <div class="space-y-6">
          {SITE.sedes.map((sede) => (
            <div class="bg-neutral-50 rounded-xl p-5 border border-neutral-200">
              <h3 class="font-bold text-neutral-900 mb-3">{sede.name}</h3>
              <div class="space-y-2 text-sm">
                <div class="flex items-start gap-3">
                  <svg class="w-4 h-4 text-brand-red mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                  <p class="text-neutral-600">{sede.address}</p>
                </div>
                <div class="flex items-center gap-3">
                  <svg class="w-4 h-4 text-brand-red flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                  <a href={`mailto:${sede.email}`} class="text-brand-red hover:underline">{sede.email}</a>
                </div>
                <div class="flex items-center gap-3">
                  <svg class="w-4 h-4 text-brand-red flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                  <a href={`tel:${sede.phoneRaw}`} class="text-neutral-600 hover:text-brand-red">{sede.phone}</a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

---
import { Image } from 'astro:assets';
import { IMAGES } from '../config/assets';
import { SITE } from '../config/site';

const heroImage = IMAGES.hero[0];
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <Image
      src={heroImage.src}
      alt={heroImage.alt}
      class="w-full h-full object-cover"
      widths={[640, 1024, 1920]}
      sizes="100vw"
      loading="eager"
      quality={80}
    />
    <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/80 via-neutral-900/60 to-neutral-900/40"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32">
    <div class="max-w-3xl">
      <p class="text-brand-red font-semibold text-sm sm:text-base uppercase tracking-widest mb-4 animate-fade-up">
        {SITE.tagline}
      </p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-white leading-tight mb-6 animate-fade-up" style="animation-delay: 0.1s">
        Conectamos el NEA<br />
        <span class="text-brand-red">con todo el país</span>
      </h1>
      <p class="text-lg sm:text-xl text-neutral-300 mb-10 max-w-xl animate-fade-up" style="animation-delay: 0.2s">
        Flota propia con monitoreo satelital 24/7. Carga general, contenedores, logística y distribución.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 animate-fade-up" style="animation-delay: 0.3s">
        <a
          href={SITE.whatsapp.link}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-8 py-4 bg-brand-red text-white font-semibold text-lg rounded-xl hover:bg-brand-red-dark transition-all duration-200 hover:shadow-lg hover:shadow-brand-red/25"
        >
          Solicitar Cotización
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="#soluciones"
          class="inline-flex items-center justify-center px-8 py-4 bg-white/10 backdrop-blur-sm text-white font-semibold text-lg rounded-xl border border-white/20 hover:bg-white/20 transition-all duration-200"
        >
          Conocer Servicios
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

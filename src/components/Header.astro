---
import { SITE } from '../config/site';
import Logo from './Logo.astro';
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-white shadow-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center group h-12" aria-label="Transporte Colussi - Inicio">
        <Logo class="h-full w-auto" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-8" aria-label="Navegación principal">
        {SITE.nav.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-neutral-900 hover:text-brand-red transition-colors duration-200"
          >
            {item.label}
          </a>
        ))}
        <a
          href={SITE.whatsapp.link}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-5 py-2.5 bg-brand-red text-white text-sm font-semibold rounded-lg hover:bg-brand-red-dark transition-colors duration-200"
        >
          Solicitar Cotización
        </a>
      </nav>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-lg hover:bg-neutral-100 transition-colors"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <svg class="w-6 h-6 text-neutral-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu drawer -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-neutral-200 shadow-lg">
    <nav class="max-w-7xl mx-auto px-4 py-4 flex flex-col gap-1" aria-label="Navegación móvil">
      {SITE.nav.map((item) => (
        <a
          href={item.href}
          class="mobile-nav-link block px-4 py-3 text-neutral-800 font-medium rounded-lg hover:bg-neutral-100 transition-colors"
        >
          {item.label}
        </a>
      ))}
      <a
        href={SITE.whatsapp.link}
        target="_blank"
        rel="noopener noreferrer"
        class="mobile-nav-link mt-2 block text-center px-4 py-3 bg-brand-red text-white font-semibold rounded-lg hover:bg-brand-red-dark transition-colors"
      >
        Solicitar Cotización
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const hamburger = document.getElementById('hamburger-icon')!;
  const closeIcon = document.getElementById('close-icon')!;

  // Mobile menu toggle
  let open = false;
  btn.addEventListener('click', () => {
    open = !open;
    menu.classList.toggle('hidden', !open);
    hamburger.classList.toggle('hidden', open);
    closeIcon.classList.toggle('hidden', !open);
    btn.setAttribute('aria-expanded', String(open));
  });

  // Close mobile menu on link click
  menu.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      open = false;
      menu.classList.add('hidden');
      hamburger.classList.remove('hidden');
      closeIcon.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    });
  });
</script>
